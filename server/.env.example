# 基础服务配置
PORT=3000
# 建议: 开发环境使用 development，生产环境使用 production
NODE_ENV=development
# 数据库配置
DB_HOST=localhost
DB_PORT=3306
# 建议: 使用最小权限应用账号
DB_USER=your_username
DB_PASS=your_password
DB_NAME=jyl
# 是否打印 SQL 日志
DB_LOGGING=false
# 建议: 生产环境设为 false，避免自动改表
DB_SYNC_ALTER=true
# 安全与运行配置
# 建议: 生产环境使用足够长度的随机密钥
JWT_SECRET=your_jwt_secret_key
# 建议: 生产环境建议设为 30d (30天) 以免用户频繁登录
JWT_EXPIRE=30d
# 默认管理员账号
ADMIN_USER=admin
ADMIN_PASS=123456
# 日志级别: INFO/DEBUG/WARN/ERROR
LOG_LEVEL=INFO
# API 全局限流(每分钟)
API_RATE_LIMIT=120
# 生产环境建议填写允许的域名(逗号分隔)
CORS_ORIGINS=
# OCR 请求超时(毫秒)
OCR_TIMEOUT_MS=10000
# 登录失败阈值与锁定时长(分钟)
LOGIN_FAIL_MAX=5
LOGIN_LOCK_MINUTES=15
# 清理任务开关与频率
CLEANUP_ENABLE=false
CLEANUP_INTERVAL_HOURS=6
VERIFY_CODE_CLEANUP_DAYS=1
ORPHAN_FILE_TTL_DAYS=7
# 分享链接有效期
SHARE_EXPIRE=7d

# 腾讯云API配置（OCR和短信共用）
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key

# 腾讯云短信配置（需要在腾讯云短信控制台开通）
SMS_APP_ID=your_sms_app_id
SMS_SIGN_NAME=甲友乐
SMS_TEMPLATE_ID=your_template_id

# 微信小程序配置
WX_APP_ID=your_wx_app_id
WX_APP_SECRET=your_wx_app_secret

# 邮件服务配置 (Gmail 示例: 587, QQ 示例: 465)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_email_password
SMTP_FROM=甲友乐

# 业务公开配置 (同步至前端)
SUPPORT_EMAIL=support@jiayoule.com
WECHAT_SUPPORT=JYL_Support
